{
  "expo": {
    "name": "monopoly",
    "slug": "monopoly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icons/ios/icon-1024.png",
    "scheme": "monopoly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./icons/ios/icon-1024.png",
      "bundleIdentifier": "com.haidang128.monopoly",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.haidang128.monopoly",
      "adaptiveIcon": {
        "backgroundColor": "#1660C8",
        "foregroundImage": "./icons/android/adaptive-foreground-432.png",
        "backgroundImage": "./icons/android/adaptive-background-432.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./icons/web/favicon-48.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-localization",
      "expo-secure-store",
      "expo-apple-authentication",
      "@sentry/react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3969197-3a8c-4232-bbd4-becf8b2bec84"
      }
    },
    "owner": "haidang812",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d3969197-3a8c-4232-bbd4-becf8b2bec84"
    }
  }
}
